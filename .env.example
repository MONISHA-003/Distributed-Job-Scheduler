# --- General ---
APP_NAME="Distributed Job Scheduler"
ENVIRONMENT="development"
DEBUG=True
API_V1_PREFIX="/api/v1"

# --- Database ---
DATABASE_URL="postgresql+asyncpg://scheduler:scheduler@postgres:5432/scheduler"
DATABASE_URL_SYNC="postgresql+psycopg2://scheduler:scheduler@postgres:5432/scheduler"
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# --- Redis / Celery ---
REDIS_URL="redis://redis:6379/0"
CELERY_BROKER_URL="redis://redis:6379/1"
CELERY_RESULT_BACKEND="redis://redis:6379/2"

# --- Auth ---
JWT_SECRET_KEY="CHANGE_ME_IN_PRODUCTION_SUPER_SECRET_KEY_123456"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Worker ---
WORKER_POLL_INTERVAL_SECONDS=1.0
WORKER_HEARTBEAT_INTERVAL_SECONDS=5.0
WORKER_HEARTBEAT_TIMEOUT_SECONDS=20
WORKER_DEFAULT_CONCURRENCY=4
WORKER_SHUTDOWN_GRACE_SECONDS=30

# --- Email / notifications ---
SMTP_HOST="mailhog"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="scheduler@example.com"
SMTP_USE_TLS=False
NOTIFY_ON_FAILURE=True
NOTIFY_ON_RETRY=False

# --- CORS ---
CORS_ORIGINS='["http://localhost:5173", "http://localhost:3000"]'
